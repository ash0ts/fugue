# Copy to .env (gitignored). W&B is always the trace plane; model calls can
# bill through W&B Inference, OpenAI, or Anthropic.

# W&B Weave tracing. WANDB_API_KEY is also the model key for wandb/... models.
WANDB_API_KEY=
WANDB_BASE_URL=https://api.wandb.ai
WANDB_ENTITY=wandb
WANDB_PROJECT=fugue-experiments
FUGUE_RUN_NAME=
FUGUE_TAGS=

# Model provider billing keys.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Model selector. CLI --model overrides this.
FUGUE_MODEL=wandb/zai-org/GLM-5.2

# Optional AI operator roles. Blank values fall back to the active experiment
# model, then FUGUE_MODEL.
FUGUE_COMPOSER_MODEL=
FUGUE_ANALYST_MODEL=

# Auth key harnesses use against the local LiteLLM bridge.
LITELLM_MASTER_KEY=sk-fugue-local

# Context-system experiments. Default presets need the context extra above;
# configure service credentials only for systems you explicitly select.
FUGUE_BUILDER_MODEL=
FUGUE_JUDGE_MODEL=
LAT_LLM_KEY=
# lat.md, CodeGraph, Project-RAG, and Semble remain opt-in until their pinned
# Harbor MCP runtimes pass integration tests.
# FUGUE_ENABLE_EXPERIMENTAL_LATMD=true
FUGUE_GRAPHITI_URI=
FUGUE_GRAPHITI_USER=neo4j
FUGUE_GRAPHITI_PASSWORD=fugue-local
# FUGUE_LICENSE_APPROVED_GITNEXUS=true

# Optional overrides.
# WANDB_INFERENCE_BASE_URL=https://api.inference.wandb.ai/v1
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# HERMES_OTEL_CHECKOUT=~/Documents/GitHub/hermes-otel
