# Copy to .env (gitignored) and fill in. Everything below is read by
# scripts/preflight.sh, scripts/smoke.sh, and the Harbor agent adapters.

# W&B: bills all model calls (W&B Inference) and receives all Weave traces.
WANDB_API_KEY=
WANDB_ENTITY=
WANDB_PROJECT=

# Optional overrides ---------------------------------------------------------

# Model served by W&B Inference (default zai-org/GLM-5.2).
# FUGUE_MODEL=zai-org/GLM-5.2

# Experimental condition stamped on every trace + trial meta (default
# "baseline"). The repo-memory study sets e.g. openwiki|deepwiki|semsearch|
# agentsmd|none per run.
# FUGUE_CONDITION=baseline

# Local checkout of the hermes-otel plugin, uploaded into Hermes containers.
# HERMES_OTEL_CHECKOUT=~/Documents/GitHub/hermes-otel

# Auth key harnesses use against the local LiteLLM bridge (any string).
# LITELLM_MASTER_KEY=sk-fugue-local
