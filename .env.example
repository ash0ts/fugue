# Copy to .env (gitignored). W&B is always the trace plane; model calls can
# bill through W&B Inference, OpenAI, or Anthropic.

# W&B Weave tracing. WANDB_API_KEY is also the model key for wandb/... models.
WANDB_API_KEY=
WANDB_ENTITY=wandb
WANDB_PROJECT=hermes_agent
FUGUE_RUN_NAME=
FUGUE_TAGS=

# Model provider billing keys.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Model selector. CLI --model overrides this.
FUGUE_MODEL=wandb/zai-org/GLM-5.2

# Auth key harnesses use against the local LiteLLM bridge.
LITELLM_MASTER_KEY=sk-fugue-local

# Optional overrides.
# WANDB_INFERENCE_BASE_URL=https://api.inference.wandb.ai/v1
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# HERMES_OTEL_CHECKOUT=~/Documents/GitHub/hermes-otel
