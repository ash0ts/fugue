FROM ghcr.io/astral-sh/uv:0.11.27@sha256:4d01caf3b22dfd11003455e2e68153da08c4ee1fa54fdbd166c6282d22693419 AS uv
FROM python:3.13.5-slim-bookworm@sha256:4c2cf9917bd1cbacc5e9b07320025bdb7cdf2df7b0ceaccb55e9dd7e30987419

COPY --from=uv /uv /uvx /bin/

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates docker.io git tini \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd --gid 10001 fugue \
    && useradd --uid 10001 --gid 10001 --create-home --shell /usr/sbin/nologin fugue

WORKDIR /opt/fugue

COPY pyproject.toml uv.lock README.md ./
COPY fugue ./fugue
COPY configs ./configs

RUN uv sync --frozen --no-dev --extra research-worker \
    && mkdir -p /workspace/.fugue /etc/fugue \
    && chown -R fugue:fugue /workspace/.fugue /etc/fugue

ENV PATH="/opt/fugue/.venv/bin:${PATH}"
ENV PYTHONPATH="/opt/fugue"
ENV PYTHONUNBUFFERED="1"

USER fugue:fugue
ENTRYPOINT ["/usr/bin/tini", "--", "fugue", "research"]
CMD ["serve", "--host", "0.0.0.0", "--port", "8787", "--repo-root", "/workspace"]
